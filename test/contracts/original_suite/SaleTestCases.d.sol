    function usdc(uint256 amount) internal pure returns (uint256) {
        return amount * 1e6;
    }

    function buy(address addr, uint256 usdcAmount) public {
        vm.startPrank(addr);
        sale.buy(sale.paymentTokenToToken(usdcAmount), merkleProofs[addr]);
        vm.stopPrank();
    }

    function test_case1() public {
        address p0 = participants[0];

        buy(p0, usdc(1_000_000));
        require(sale.allocation(p0) == usdc(1_000_000));

        buy(p0, usdc(2_000_000));
        require(sale.allocation(p0) == 0);

        vm.warp(sale.end() + 1000);

        vm.startPrank(owner);
        sale.setIndividualCap(usdc(2_000_000));
        require(uint256(sale.risingTideState()) == 2);
        vm.stopPrank();

        require(sale.allocation(p0) == usdc(2_000_000));
        require(sale.refundAmount(p0) == usdc(1_000_000));
    }

    function test_case2() public {
        address p0 = participants[0];
        address p1 = participants[1];

        buy(p0, usdc(1_000_000));
        require(sale.allocation(p0) == usdc(1_000_000));

        buy(p1, usdc(2_000_000));
        require(sale.allocation(p0) == 0);
        require(sale.allocation(p1) == 0);

        vm.warp(sale.end() + 1000);

        vm.startPrank(owner);
        sale.setIndividualCap(usdc(1_000_000));
        require(uint256(sale.risingTideState()) == 2);
        vm.stopPrank();

        require(sale.allocation(p0) == usdc(1_000_000));
        require(sale.refundAmount(p0) == usdc(0));

        require(sale.allocation(p1) == usdc(1_000_000));
        require(sale.refundAmount(p1) == usdc(1_000_000));
    }

    function test_case3() public {
        address p0 = participants[0];
        address p1 = participants[1];
        address p2 = participants[2];
        address p3 = participants[3];
        address p4 = participants[4];

        buy(p0, usdc(100_000));
        require(sale.allocation(p0) == usdc(100_000));

        buy(p1, usdc(500_000));
        require(sale.allocation(p0) == usdc(100_000));
        require(sale.allocation(p1) == usdc(500_000));

        buy(p2, usdc(800_000));
        require(sale.allocation(p0) == usdc(100_000));
        require(sale.allocation(p1) == usdc(500_000));
        require(sale.allocation(p2) == usdc(800_000));

        buy(p3, usdc(1_000_000));
        require(sale.allocation(p0) == 0);
        require(sale.allocation(p1) == 0);
        require(sale.allocation(p2) == 0);
        require(sale.allocation(p3) == 0);

        buy(p4, usdc(2_500_000));
        require(sale.allocation(p0) == 0);
        require(sale.allocation(p1) == 0);
        require(sale.allocation(p2) == 0);
        require(sale.allocation(p3) == 0);
        require(sale.allocation(p4) == 0);

        vm.warp(sale.end() + 1000);

        uint256 individualCap = 475_000;

        vm.startPrank(owner);
        sale.setIndividualCap(usdc(individualCap));
        require(uint256(sale.risingTideState()) == 2);
        vm.stopPrank();

        require(sale.allocation(p0) == usdc(100_000));
        require(sale.refundAmount(p0) == usdc(0));

        require(sale.allocation(p1) == usdc(individualCap));
        require(sale.refundAmount(p1) == usdc(500_000 - individualCap));

        require(sale.allocation(p2) == usdc(individualCap));
        require(sale.refundAmount(p2) == usdc(800_000 - individualCap));

        require(sale.allocation(p3) == usdc(individualCap));
        require(sale.refundAmount(p3) == usdc(1_000_000 - individualCap));

        require(sale.allocation(p4) == usdc(individualCap));
        require(sale.refundAmount(p4) == usdc(2_500_000 - individualCap));
    }

